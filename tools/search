#!/usr/bin/env bash

OUT_FILE="index.txt"

echo "Creating index of all tracked files..."
# If using git, `git ls-files` is much cleaner than find. 
# Falling back to find if git isn't available.
if git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    git ls-files > "$OUT_FILE"
else
    command find . -type f -not -path '*/\.git/*' > "$OUT_FILE"
fi

echo "Saved to $OUT_FILE"