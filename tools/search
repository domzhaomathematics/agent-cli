#!/usr/bin/env bash

QUERY="$1"

if [[ -z "$QUERY" ]]; then
    echo "Usage: agent search <filename-part>"
    exit 1
fi

echo "Searching for '*$QUERY*'..."
command find . -name "*$QUERY*" -not -path '*/\.git/*'
