#!/usr/bin/env bash
if [[ -z "$SESSION_DIR" ]]; then echo "[Error] Session not active."; exit 1; fi

if [[ $# -gt 0 ]]; then
    echo "[Warning] 'agent ask' is interactive. Inline arguments are ignored."
fi

PROMPT=""

while true; do
    # Initial State or State B (No script proposed)
    if [[ -z "$PROMPT" ]]; then
        echo -n "[Ctrl+C] to exit | ask agent: "
        read -r PROMPT || exit 0
    fi
    
    # If the user just hits Enter, loop back to the prompt
    if [[ -z "$PROMPT" ]]; then continue; fi

    # Echo explicitly so the script logger captures the question for future context
    echo "User: $PROMPT"

    TMP_LOGS="$AGENT_DIR/tmp_logs.txt"
    "$AGENT_DIR/tools/logs" 150 -q > "$TMP_LOGS"
    if [[ -x "$AGENT_DIR/tools/update" ]]; then "$AGENT_DIR/tools/update" -q; fi

    TOK_CTX=$(($(wc -m < "$SESSION_DIR/context.txt" 2>/dev/null || echo 0) / 3))
    TOK_LOG=$(($(wc -m < "$TMP_LOGS" 2>/dev/null || echo 0) / 3))
    TOK_TOT=$((TOK_CTX + TOK_LOG))

    echo "[Token Estimate] Total: ${TOK_TOT} | Context: ${TOK_CTX} | Logs: ${TOK_LOG}"

    if (( TOK_TOT > 200000 )); then
        echo "[Alert] Context exceeds 200k tokens. High cost and severe degradation risk."
        echo "Tip: Use 'agent context' to find large files, and 'agent unread <path>' to remove them."
        read -p "Proceed? [y/N]: " proceed
        if [[ ! "$proceed" =~ ^[Yy]$ ]]; then rm -f "$TMP_LOGS"; PROMPT=""; continue; fi
    elif (( TOK_TOT > 100000 )); then
        echo "[Warning] Context exceeds 100k tokens. Performance may degrade."
    fi

    echo "Thinking (Model: $AGENT_MODEL)..."

    SYS_PROMPT="You are a precise, highly skilled coding assistant. You must provide concise, dense text explanations. Do not use conversational filler.
If actions (creating files, executing commands) are required, output AT MOST ONE \`bash\` code block (using \`\`\`bash).
Even if multiple files need creating or editing, combine them into this SINGLE script using \`cat << 'EOF'\`, \`sed\`, or other shell utilities. Provide exactly one bash block if code execution is needed."

    PAYLOAD_FILE="$AGENT_DIR/payload.json"
    jq -n --arg pmt "$PROMPT" --arg sys "$SYS_PROMPT" '{"contents":[{"parts":[{"text": ($sys + "\n\nUser Question:\n" + $pmt)}]}]}' > "$PAYLOAD_FILE"

    if [[ -s "$SESSION_DIR/context.txt" ]]; then jq --rawfile raw "$SESSION_DIR/context.txt" '.contents[0].parts[0].text = "Project Context:\n" + $raw + "\n" + .contents[0].parts[0].text' "$PAYLOAD_FILE" > "${PAYLOAD_FILE}.tmp" && mv "${PAYLOAD_FILE}.tmp" "$PAYLOAD_FILE"; fi
    if [[ -s "$TMP_LOGS" ]]; then jq --rawfile raw "$TMP_LOGS" '.contents[0].parts[0].text = "Terminal Logs:\n" + $raw + "\n" + .contents[0].parts[0].text' "$PAYLOAD_FILE" > "${PAYLOAD_FILE}.tmp" && mv "${PAYLOAD_FILE}.tmp" "$PAYLOAD_FILE"; fi
    if [[ -f "$SESSION_DIR/plan.md" ]]; then jq --rawfile raw "$SESSION_DIR/plan.md" '.contents[0].parts[0].text = "Mission Plan:\n" + $raw + "\n" + .contents[0].parts[0].text' "$PAYLOAD_FILE" > "${PAYLOAD_FILE}.tmp" && mv "${PAYLOAD_FILE}.tmp" "$PAYLOAD_FILE"; fi

    RESPONSE=$(curl -s -X POST "https://generativelanguage.googleapis.com/v1beta/models/${AGENT_MODEL}:generateContent?key=$GEMINI_API_KEY" \
        -H "Content-Type: application/json" -d @"$PAYLOAD_FILE")

    rm -f "$PAYLOAD_FILE" "$TMP_LOGS"

    RESULT=$(echo "$RESPONSE" | jq -r '.candidates[0].content.parts[0].text // empty')
    if [[ -z "$RESULT" ]]; then
        echo "[API Error] $(echo "$RESPONSE" | jq -r '.error.message // "Unknown Error"')"
        PROMPT=""
        continue
    fi

    # Parse out the pure text and pure bash script blocks safely
    TEXT_PART=$(echo "$RESULT" | awk '/^```bash/ { in_code = 1; next } /^```/ { if (in_code) { in_code = 0; next } } { if (!in_code) print }')
    SCRIPT_PART=$(echo "$RESULT" | awk '/^```bash/ { in_code = 1; next } /^```/ { if (in_code) { in_code = 0; next } } { if (in_code) print }')

    echo -e "\n$TEXT_PART\n"

    # State A: Script is proposed
    if [[ -n "$SCRIPT_PART" && "$SCRIPT_PART" != $'\n' ]]; then
        echo "---[ SCRIPT BLOCK START ]---"
        echo "$SCRIPT_PART"
        echo "---[ SCRIPT BLOCK END ]---"
        echo ""
        echo -n "[Enter] to run script | [Ctrl+C] to exit | ask agent: "
        read -r USER_INPUT || exit 0
        if [[ -z "$USER_INPUT" ]]; then
            TMP_SCRIPT="$AGENT_DIR/tmp_run.sh"
            echo "$SCRIPT_PART" > "$TMP_SCRIPT"
            chmod +x "$TMP_SCRIPT"
            echo -e "\n[Executing Script...]"
            bash "$TMP_SCRIPT"
            rm -f "$TMP_SCRIPT"
            echo -e "[Execution Complete]\n"
            PROMPT=""
        else
            PROMPT="$USER_INPUT"
        fi
    else
        # State B: No script proposed
        # We set PROMPT="" so the loop restarts and cleanly shows the default prompt
        PROMPT=""
    fi
done