#!/usr/bin/env bash

PROMPT="$1"
OUT_FILE="$AGENT_DIR/context.txt"
PAYLOAD_FILE="$AGENT_DIR/payload.json"

if [[ -z "$GEMINI_API_KEY" ]]; then echo "❌ GEMINI_API_KEY not set."; exit 1; fi
if [[ -z "$PROMPT" ]]; then echo "Usage: agent ask \"prompt\""; exit 1; fi

if [[ -s "$OUT_FILE" ]]; then
    jq -Rs --arg pmt "$PROMPT" '{"contents": [{"parts":[{"text": ("Codebase context:\n\n" + . + "\n\nUser Question:\n" + $pmt)}]}]}' < "$OUT_FILE" > "$PAYLOAD_FILE"
else
    jq -n --arg pmt "$PROMPT" '{"contents": [{"parts":[{"text": $pmt}]}]}' > "$PAYLOAD_FILE"
fi

RESPONSE=$(curl -s -X POST "https://generativelanguage.googleapis.com/v1beta/models/gemini-3-flash-preview:generateContent?key=$GEMINI_API_KEY" \
    -H "Content-Type: application/json" -d @"$PAYLOAD_FILE")

rm -f "$PAYLOAD_FILE"

ERROR_MSG=$(echo "$RESPONSE" | jq -r '.error.message // empty')
if [[ -n "$ERROR_MSG" ]]; then echo "❌ API Error: $ERROR_MSG"; exit 1; fi

# EXACTLY and ONLY the raw response
echo "$RESPONSE" | jq -r '.candidates[0].content.parts[0].text // "❌ Could not parse response."'