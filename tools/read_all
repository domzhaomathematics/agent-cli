#!/usr/bin/env bash
OUT_FILE="$SESSION_DIR/context.txt"
echo -e "\n\n-->[read_all] Generating directory structure..." >> "$OUT_FILE"
command find . -not -path '*/\.*' -not -path '*/node_modules/*' -not -path '*/venv/*' -not -path '*/build/*' -not -path '*/__pycache__/*' -not -path "$AGENT_DIR/*" | sort >> "$OUT_FILE"
echo -e "\n--> [read_all] File Contents:" >> "$OUT_FILE"
command find . -type f -not -path '*/\.*' -not -path '*/node_modules/*' -not -path '*/venv/*' -not -path '*/build/*' -not -path '*/__pycache__/*' -not -path "$AGENT_DIR/*" -size -1024k | while read -r file; do
    if ! file "$file" | grep -qiE 'text|json|csv|xml|empty'; then continue; fi
    echo -e "\n========================================\nFile: $file\n========================================" >> "$OUT_FILE"
    cat "$file" >> "$OUT_FILE"
done
MSG="[Session: $SESSION_NAME] ✔ Appended full safe directory to context."
echo "$MSG"
if [[ "$SESSION_NAME" != "Global" ]]; then echo "$MSG" >> "$SESSION_DIR/history.txt"; fi