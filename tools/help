#!/usr/bin/env bash

if [[ -n "$SESSION_NAME" ]]; then S_DISPLAY="$SESSION_NAME"; else S_DISPLAY="None (Global Mode)"; fi

echo -e "\n🤖 Agent CLI - Minimalist AI Workspace"
echo "Current Session: [$S_DISPLAY]"
echo -e "\n--- Workspaces ---"
echo "  start <name>          : Start and bind terminal to a new workspace"
echo "  resume <name>         : Bind current terminal to an existing workspace"
echo "  stop                  : Unbind terminal (Return to Global mode)"
echo "  list                  : List all active workspaces"
echo "  delete <name>         : Permanently delete a workspace and its history"
echo -e "\n--- Actions ---"
echo "  ask <prompt>          : Ask Gemini (Uses Memory + Context + History)"
echo "  do <prompt>           : Ask Gemini for a one-line command (Interactive review)"
echo "  run <command>         : Run a bash command and log output to session history"
echo -e "\n--- Context Management ---"
echo "  read <file/path>      : Append a file to current session's context"
echo "  read_all              : Append all safe files in folder to session's context"
echo "  clear_context         : Empty the current session's context"
echo "  memorize_all          : Scan project and build global memory.txt map"
echo ""
