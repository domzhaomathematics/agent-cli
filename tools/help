#!/usr/bin/env bash

if [[ -n "$SESSION_NAME" ]]; then S_DISPLAY="$SESSION_NAME"; else S_DISPLAY="None (Global Mode)"; fi

echo -e "\n🤖 Agent-CLI V2 - Absolute Context & Token Management"
echo "Current Session: [$S_DISPLAY]"
echo "Current Model:   $AGENT_MODEL"

echo -e "\n--- 🧠 Brain & Context ---"
echo "  read <path>           : Load file/dir into context (Defaults to current dir)"
echo "                          Flags: --except dir1,file2 | --only-paths"
echo "  unread <path>         : Surgically remove a file or directory from context"
echo "  clear                 : Wipe all context for the current session"
echo "  context               : Dashboard (df -h) showing loaded files and token counts"

echo -e "\n--- 💬 Interaction ---"
  plan <goal>           : Iteratively build a mission plan (plan.md)
echo "  ask <prompt>          : Ask Gemini using all loaded context + history"
echo "                          Flag: -s or -smartest to use Gemini 3.1 Pro"

echo -e "\n--- 🏗️ Workspaces ---"
echo "  start <name>          : Create and bind to a new workspace"
echo "  resume <name>         : Bind terminal to an existing workspace"
echo "  stop                  : Unbind and return to Global mode"
echo "  list                  : Show all sessions"
echo "  delete <name>         : Permanently delete a session"

echo -e "\n--- 💡 Pro-Tips ---"
echo "  - Absolute Paths: We use full paths internally so the AI never gets lost."
echo "  - Token Budget: Context is estimated at (chars / 3). Monitor with 'agent context'."
echo "  - Smartest Tier: Use 'agent ask -s' when you need high-level architectural reasoning."
echo ""