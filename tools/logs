#!/usr/bin/env bash
if [[ -z "$SESSION_DIR" ]]; then echo "[Error] Session not active."; exit 1; fi

LOG_FILE="$SESSION_DIR/logs/terminal_raw.log"
if [[ ! -f "$LOG_FILE" ]]; then exit 0; fi

LINES=${1:-150}
QUIET=0
if [[ "$1" == "-q" || "$2" == "-q" ]]; then QUIET=1; fi

if [[ $QUIET -eq 0 ]]; then echo -e "\n--- RAW TERMINAL LOGS (Last $LINES lines) ---"; fi

# No awk, no perl, no regex. 
# Just grab the last lines and make all hidden characters safely visible.
tail -n "$LINES" "$LOG_FILE" | cat -v

if [[ $QUIET -eq 0 ]]; then echo -e "--------------------------------------------------\n"; fi