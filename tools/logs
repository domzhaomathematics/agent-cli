#!/usr/bin/env bash
if [[ -z "$SESSION_DIR" ]]; then echo "❌ Error: Session not active."; exit 1; fi

LOG_FILE="$SESSION_DIR/logs/terminal_raw.log"
if [[ ! -f "$LOG_FILE" ]]; then 
    echo "No logs found yet."
    exit 0
fi

LINES=${1:-50} 

echo -e "\n--- FILTERED TERMINAL LOGS (Last $LINES lines) ---"

# 1. Perl strips the ANSI colors/Zsh paste codes
# 2. col -b cleans up carriage returns
# 3. grep -a -v removes the CLI's own UI banners so they don't echo infinitely!
cat "$LOG_FILE" \
    | perl -pe 's/\x1b\[[\x30-\x3F]*[\x20-\x2F]*[\x40-\x7E]//g' \
    | perl -pe 's/\x1b\][^\x07\x1b]*[\x07\x1b]//g' \
    | perl -pe 's/\x1b[()][A-Z0-9]//g' \
    | col -b \
    | grep -a -v -E "(FILTERED TERMINAL LOGS|--------------------------------------------------|==================== ANSWER ====================|🤖 Thinking|💬 Thinking)" \
    | tail -n "$LINES"

echo -e "--------------------------------------------------\n"