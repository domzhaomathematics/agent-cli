#!/usr/bin/env bash
FILE="$1"
OUT_FILE="$SESSION_DIR/context.txt"
if [[ -z "$FILE" ]]; then echo "Usage: agent read <filename>"; exit 1; fi
if [[ -f "$FILE" ]]; then TARGET="$FILE"
elif [[ -f "$AGENT_DIR/$FILE" ]]; then TARGET="$AGENT_DIR/$FILE"
else MSG="[Session: $SESSION_NAME] ❌ Error: '$FILE' not found."; echo "$MSG"; [[ "$SESSION_NAME" != "Global" ]] && echo "$MSG" >> "$SESSION_DIR/history.txt"; exit 1; fi
if [[ -z $(command find "$TARGET" -type f -size -1024k) ]]; then MSG="[Session: $SESSION_NAME] ❌ Error: File > 1MB."; echo "$MSG"; [[ "$SESSION_NAME" != "Global" ]] && echo "$MSG" >> "$SESSION_DIR/history.txt"; exit 1; fi
if ! file "$TARGET" | grep -qiE 'text|json|csv|xml|empty'; then MSG="[Session: $SESSION_NAME] ❌ Error: Binary file."; echo "$MSG"; [[ "$SESSION_NAME" != "Global" ]] && echo "$MSG" >> "$SESSION_DIR/history.txt"; exit 1; fi
echo -e "\n========================================\nFile: $TARGET\n========================================" >> "$OUT_FILE"
cat "$TARGET" >> "$OUT_FILE"
MSG="[Session: $SESSION_NAME] ✔ Appended '$TARGET' to context."
echo "$MSG"
if [[ "$SESSION_NAME" != "Global" ]]; then echo "$MSG" >> "$SESSION_DIR/history.txt"; fi