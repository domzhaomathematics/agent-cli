#!/usr/bin/env bash

FILE="$1"
OUT_FILE="$AGENT_DIR/context.txt"
MAX_SIZE="1024k"

if [[ -z "$FILE" || ! -f "$FILE" ]]; then
    echo "Usage: agent read <filename>"
    exit 1
fi

# Layer 1: Size check. If find doesn't output the filename, it's too big!
if [[ -z $(command find "$FILE" -type f -size -"$MAX_SIZE") ]]; then
    echo "❌ Error: '$FILE' is larger than 1MB. Skipping to protect memory."
    exit 1
fi

# Layer 2: Content type check. Ensure it's text-based data.
if ! file "$FILE" | grep -qiE 'text|json|csv|xml|empty'; then
    echo "❌ Error: '$FILE' appears to be a binary/non-text file. Skipping."
    exit 1
fi

echo -e "\n========================================" >> "$OUT_FILE"
echo "File: $FILE" >> "$OUT_FILE"
echo "========================================" >> "$OUT_FILE"
cat "$FILE" >> "$OUT_FILE"

echo "✔ Appended '$FILE' safely to context.txt"