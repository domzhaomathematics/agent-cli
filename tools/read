#!/usr/bin/env bash
if [[ -z "$SESSION_DIR" ]]; then echo "[Error] No session active."; exit 1; fi

TARGET="."
EXCEPT=""
ONLY_PATHS=false

ARGS=()
while [[ "$#" -gt 0 ]]; do
    if [[ "$1" == "except" ]]; then
        EXCEPT="$2"
        shift 2
    elif [[ "$1" == "--only-paths" ]]; then
        ONLY_PATHS=true
        shift
    else
        ARGS+=("$1")
        shift
    fi
done

if [[ ${#ARGS[@]} -gt 0 ]]; then TARGET="${ARGS[0]}"; fi

ABS_TARGET=$(realpath "$TARGET" 2>/dev/null || echo "$TARGET")
OUT_FILE="$SESSION_DIR/context.txt"
touch "$OUT_FILE"

process_file() {
    local abs_f=$(realpath "$1")
    local rel_f="./${abs_f#$PWD/}"
    local is_update=false
    
    if grep -q -F -e "---[ FILE: $abs_f |" "$OUT_FILE"; then
        "$AGENT_DIR/tools/unread" "$abs_f" >/dev/null 2>&1
        is_update=true
    fi

    local size_bytes=$(wc -c < "$abs_f" 2>/dev/null || echo 0)
    if (( size_bytes > 1048576 )); then echo "   [Skipped >1MB] $rel_f"; return; fi

    if [[ -s "$abs_f" ]]; then
        local enc=$(file -b --mime-encoding "$abs_f" 2>/dev/null)
        if [[ "$enc" == "binary" ]]; then return; fi
    fi

    if [[ "$ONLY_PATHS" == true ]]; then
        echo "---[ FILE: $abs_f | Tokens: 5 | Mode: PATH_ONLY ]---" >> "$OUT_FILE"
        echo "---[ END: $abs_f ]---" >> "$OUT_FILE"
        if [[ "$is_update" == true ]]; then echo "   [Updated Path] $rel_f"; else echo "   [Path Only] $rel_f"; fi
    else
        local chars=$(wc -m < "$abs_f" 2>/dev/null || echo 0)
        local tk=$((chars / 3))
        echo "---[ FILE: $abs_f | Tokens: $tk | Mode: FULL ]---" >> "$OUT_FILE"
        cat "$abs_f" >> "$OUT_FILE"
        echo -e "\n---[ END: $abs_f ]---" >> "$OUT_FILE"
        
        if [[ "$is_update" == true ]]; then echo "   [Updated] $rel_f (~$tk tokens)"; else echo "   [Added] $rel_f (~$tk tokens)"; fi
    fi
}

FIND_CMD=(find "$ABS_TARGET" -type f -not -path '*/.*')
if [[ -n "$EXCEPT" ]]; then
    IFS=',' read -ra ADDR <<< "$EXCEPT"
    for part in "${ADDR[@]}"; do FIND_CMD+=(-not -path "*/$part/*" -not -name "$part"); done
fi

if [[ -f "$ABS_TARGET" ]]; then process_file "$ABS_TARGET"
else while read -r file; do process_file "$file"; done < <("${FIND_CMD[@]}" 2>/dev/null); fi