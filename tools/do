#!/usr/bin/env bash
if [[ -z "$GEMINI_API_KEY" ]]; then echo "❌ GEMINI_API_KEY not set."; exit 1; fi
if ! command -v jq &> /dev/null; then echo "❌ Error: 'jq' is missing."; exit 1; fi

PROMPT="$*"
if [[ -z "$PROMPT" ]]; then echo "Usage: agent do <prompt>"; exit 1; fi

# THE FIX: Explicit instructions for relative paths and multi-command context gathering!
FULL_PROMPT="$PROMPT\n\n[SYSTEM INSTRUCTION]: Write a very brief explanation, and put the exact terminal command(s) or script inside a \`\`\`bash code block. This code will be executed in the user's current directory. CRITICAL RULE: If you lack the necessary context to safely complete the request, DO NOT GUESS. Instead, generate commands to gather the missing information. You can use standard Linux commands (ls, find, grep) to explore, OR use \`agent read <relative_filepath>\` to permanently append a file into the session context. If you need multiple files or pieces of info, you can output multiple commands (chained or as a multi-line script) to gather everything at once. Output ONLY the gathering commands."

TMP_CONTEXT="$AGENT_DIR/tmp_context.txt"
> "$TMP_CONTEXT"

if [[ -s "$AGENT_DIR/memory.txt" ]]; then echo -e "--- GLOBAL PROJECT MAP ---\n$(cat "$AGENT_DIR/memory.txt")\n\n" >> "$TMP_CONTEXT"; fi
if [[ -s "$SESSION_DIR/context.txt" ]]; then echo -e "--- SESSION CONTEXT ---\n$(cat "$SESSION_DIR/context.txt")\n\n" >> "$TMP_CONTEXT"; fi
if [[ -s "$SESSION_DIR/history.txt" && -n "$SESSION_NAME" ]]; then echo -e "--- TERMINAL TRANSCRIPT ---\n$(cat "$SESSION_DIR/history.txt")\n\n" >> "$TMP_CONTEXT"; fi

PAYLOAD_FILE="$AGENT_DIR/payload.json"
MSG_GEN="[Session: $SESSION_NAME] 🤖 Generating command..."
echo "$MSG_GEN"

jq -Rs --arg pmt "$FULL_PROMPT" '{"contents":[{"parts":[{"text": ("Codebase & Transcript:\n\n" + . + "\n\nUser Question:\n" + $pmt)}]}]}' < "$TMP_CONTEXT" > "$PAYLOAD_FILE"
rm -f "$TMP_CONTEXT"

RESPONSE=$(curl -s -X POST "https://generativelanguage.googleapis.com/v1beta/models/gemini-3-flash-preview:generateContent?key=$GEMINI_API_KEY" -H "Content-Type: application/json" -d @"$PAYLOAD_FILE")
rm -f "$PAYLOAD_FILE"

ERROR_MSG=$(echo "$RESPONSE" | jq -r '.error.message // empty')
if [[ -n "$ERROR_MSG" ]]; then echo "❌ API Error: $ERROR_MSG"; exit 1; fi
RAW_ANSWER=$(echo "$RESPONSE" | jq -r '.candidates[0].content.parts[0].text // "❌ Could not parse response."')

# Grab the ENTIRE code block
SUGGESTED_CMD=$(echo "$RAW_ANSWER" | sed -n '/^```bash/,/^```/ p' | sed '/^```/ d')

if [[ -z "$SUGGESTED_CMD" ]]; then 
    echo -e "[Session: $SESSION_NAME] ❌ Error: Gemini did not output a bash command.\n$RAW_ANSWER"
    exit 1
fi

EXPLANATION=$(echo "$RAW_ANSWER" | sed '/^```bash/,/^```/ d')
echo -e "\n🤖 Gemini:\n$EXPLANATION\n"

# Count lines
LINE_COUNT=$(echo "$SUGGESTED_CMD" | wc -l | xargs)

if [[ "$LINE_COUNT" -eq 1 ]]; then
    # SINGLE LINE
    P_USER=$(whoami 2>/dev/null || echo "user")
    P_HOST=$(hostname 2>/dev/null || echo "host")
    P_DIR=$(pwd | sed "s|^$HOME|~|")
    SIMULATED_PROMPT="${P_USER}@${P_HOST}:${P_DIR}\$ "

    read -e -i "$SUGGESTED_CMD" -p "$SIMULATED_PROMPT" FINAL_CMD

    if [[ -n "$FINAL_CMD" ]]; then
        "$AGENT_DIR/agent" run "$FINAL_CMD"
    fi
else
    # MULTI-LINE
    echo "================ COMMAND ================"
    echo -e "\033[36m$SUGGESTED_CMD\033[0m" 
    echo "========================================="
    echo -ne "👉 Press [Enter] to execute, or[Ctrl+C] to cancel: "
    read -r choice

    if [[ -z "$choice" ]]; then
        echo ""
        "$AGENT_DIR/agent" run "$SUGGESTED_CMD"
    else
        echo "❌ Cancelled."
    fi
fi
