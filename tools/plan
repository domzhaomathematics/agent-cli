#!/usr/bin/env bash
if [[ -z "$SESSION_DIR" ]]; then echo "[Error] Session not active."; exit 1; fi
export AGENT_MODEL="gemini-3.1-pro-preview"

GOAL="$*"
if [[ -z "$GOAL" ]]; then echo -n "What is your goal? "; read -r GOAL; fi

CURRENT_PROPOSAL=""
FEEDBACK=""

while true; do
    TMP_LOGS="$AGENT_DIR/tmp_logs.txt"
    "$AGENT_DIR/tools/logs" 150 -q > "$TMP_LOGS"
    if [[ -x "$AGENT_DIR/tools/update" ]]; then "$AGENT_DIR/tools/update" -q; fi

    TOK_CTX=$(($(wc -m < "$SESSION_DIR/context.txt" 2>/dev/null || echo 0) / 3))
    TOK_LOG=$(($(wc -m < "$TMP_LOGS" 2>/dev/null || echo 0) / 3))
    TOK_TOT=$((TOK_CTX + TOK_LOG))

    echo "[Token Estimate] Total: ${TOK_TOT} | Context: ${TOK_CTX} | Logs: ${TOK_LOG}"

    if (( TOK_TOT > 200000 )); then
        read -p "[Alert] Context > 200k tokens. Proceed? [y/N]: " proceed
        if [[ ! "$proceed" =~ ^[Yy]$ ]]; then rm -f "$TMP_LOGS"; exit 0; fi
    elif (( TOK_TOT > 100000 )); then
        echo "[Warning] Context exceeds 100k tokens."
    fi

    echo "Thinking (Model: $AGENT_MODEL)..."
    
    EXISTING_PLAN=""
    if [[ -f "$SESSION_DIR/plan.md" ]]; then
        EXISTING_PLAN="--- EXISTING MISSION PLAN ---
$(cat "$SESSION_DIR/plan.md")
---------------------------"
    fi

    PROMPT="You are an expert technical project planner.
${EXISTING_PLAN}
NEW GOAL / REQUEST: $GOAL
${FEEDBACK:+USER FEEDBACK ON PREVIOUS DRAFT: $FEEDBACK}

INSTRUCTIONS:
1. If an EXISTING MISSION PLAN is provided, heavily factor it into your response. Update, refine, or rewrite it based on the NEW GOAL and context.
2. If the new goal is an addition, adapt the existing plan accordingly.
3. If there is no existing plan, create one from scratch.

FORMAT REQUIREMENTS:
1. '## Goal': A single, concise paragraph defining the objective.
2. '## The Plan': A numbered list of sequential steps.
3. '## Completion Criteria': Explicitly state how we know this goal is finished.
Output ONLY the Markdown content."

    PAYLOAD_FILE="$AGENT_DIR/payload.json"
    jq -n --arg pmt "$PROMPT" '{"contents":[{"parts":[{"text": $pmt}]}]}' > "$PAYLOAD_FILE"
    
    if [[ -s "$SESSION_DIR/context.txt" ]]; then jq --rawfile raw "$SESSION_DIR/context.txt" '.contents[0].parts[0].text = "Project Context:\n" + $raw + "\n" + .contents[0].parts[0].text' "$PAYLOAD_FILE" > "${PAYLOAD_FILE}.tmp" && mv "${PAYLOAD_FILE}.tmp" "$PAYLOAD_FILE"; fi
    if [[ -s "$TMP_LOGS" ]]; then jq --rawfile raw "$TMP_LOGS" '.contents[0].parts[0].text = "Terminal Logs:\n" + $raw + "\n" + .contents[0].parts[0].text' "$PAYLOAD_FILE" > "${PAYLOAD_FILE}.tmp" && mv "${PAYLOAD_FILE}.tmp" "$PAYLOAD_FILE"; fi
    
    RESPONSE=$(curl -s -X POST "https://generativelanguage.googleapis.com/v1beta/models/${AGENT_MODEL}:generateContent?key=$GEMINI_API_KEY" \
      -H "Content-Type: application/json" -d @"$PAYLOAD_FILE")
    
    CURRENT_PROPOSAL=$(echo "$RESPONSE" | jq -r '.candidates[0].content.parts[0].text // empty')
    
    rm -f "$PAYLOAD_FILE" "$TMP_LOGS"
    
    if [[ -z "$CURRENT_PROPOSAL" ]]; then echo "[API Error] $(echo "$RESPONSE" | jq -r '.error.message // "Unknown error"')"; exit 1; fi
    
    echo -e "\n==================== PROPOSED PLAN ====================\n"
    echo "$CURRENT_PROPOSAL"
    echo -e "\n======================================================="
    
    echo -ne "\n[y] Accept | [n] Cancel | or type feedback to refine: "
    read -r USER_INPUT
    
    case "$USER_INPUT" in
        y|Y|yes|Yes) echo "$CURRENT_PROPOSAL" > "$SESSION_DIR/plan.md"; echo -e "\n[Success] Plan saved to plan.md!"; break ;;
        n|N|no|No) echo -e "\nPlanning cancelled."; break ;;
        *) FEEDBACK="$USER_INPUT" ;;
    esac
done