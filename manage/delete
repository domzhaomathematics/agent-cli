#!/usr/bin/env bash

NAME="$1"

if [[ -z "$NAME" ]]; then 
    echo "Usage: agent delete <name>"
    exit 1
fi

if [[ "$NAME" == ".bindings" ]]; then
    echo "❌ Error: Cannot delete internal system folders."
    exit 1
fi

S_DIR="$AGENT_DIR/sessions/$NAME"

if [[ ! -d "$S_DIR" ]]; then 
    echo "❌ Error: Session '$NAME' does not exist."
    exit 1
fi

# Safely delete the session folder
rm -rf "$S_DIR"

# If ANY terminal was bound to this session, unbind it
for binding in "$AGENT_DIR/sessions/.bindings"/*; do
    if [[ -f "$binding" && "$(cat "$binding")" == "$NAME" ]]; then
        rm -f "$binding"
    fi
done

echo "[Global] 🗑️  Session '$NAME' completely deleted."

# Give the user immediate feedback if they just deleted their active session
if [[ "$SESSION_NAME" == "$NAME" ]]; then
    echo "[Global] 🛑 Active terminal unbound. Returned to global mode."
fi