#!/usr/bin/env bash
AGENT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]:-$0}")")"
BIN_DIR="$HOME/.local/bin"
RC_FILE="$HOME/.bashrc"
if [[ "$(basename "$SHELL")" == "zsh" ]]; then RC_FILE="$HOME/.zshrc"; fi

echo -e "\n⚙️  Setting up agent-cli...\n"

# Create core folder architecture if it doesn't exist
mkdir -p "$AGENT_DIR/tools" "$AGENT_DIR/sequence" "$AGENT_DIR/sessions/.bindings"

if ! command -v jq &> /dev/null; then
    echo "   📦 'jq' is missing. Attempting to install (may ask for sudo)..."
    if command -v apt-get &> /dev/null; then sudo apt-get update -qq && sudo apt-get install -y jq; fi
    echo "   ✔ 'jq' installed."
fi

chmod +x "$AGENT_DIR/agent" "$AGENT_DIR/setup" 2>/dev/null
chmod +x "$AGENT_DIR"/tools/* 2>/dev/null
chmod +x "$AGENT_DIR"/sequence/* 2>/dev/null
echo "   ✔ Scripts made executable."

mkdir -p "$BIN_DIR"
ln -sf "$AGENT_DIR/agent" "$BIN_DIR/agent"
echo "   ✔ Symlink created ($BIN_DIR/agent)."

if ! grep -q "$BIN_DIR" "$RC_FILE" 2>/dev/null; then
    echo -e "\nexport PATH=\"\$HOME/.local/bin:\$PATH\"" >> "$RC_FILE"
    echo "   ✔ PATH updated in $(basename "$RC_FILE")."
fi

if ! grep -q "GEMINI_API_KEY" "$RC_FILE" 2>/dev/null; then
    echo -ne "\n🤖 Configure Gemini 3 Flash API Key? (y/n): "
    read -r config_ai
    if [[ "$config_ai" =~ ^[Yy]$ ]]; then
        echo -ne "   Paste your API Key (input hidden): "
        read -s api_key; echo ""
        if [[ -n "$api_key" ]]; then 
            echo "export GEMINI_API_KEY=\"$api_key\"" >> "$RC_FILE"
            echo "   ✔ API Key securely saved."
        fi
    fi
fi

echo -e "\n✅ Setup complete!"
echo -e "\n-------------------------------------------------------"
echo -e " 🚀 HOW TO START"
echo -e "-------------------------------------------------------"
echo -e " To use 'agent' right now in this window, run:"
echo -e " 👉  source $RC_FILE\n"
echo -e " (Or simply close this and open a new terminal window)\n"
echo -e " Then try your first command:"
echo -e "     agent help"
echo -e "-------------------------------------------------------\n"