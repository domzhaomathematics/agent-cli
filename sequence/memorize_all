#!/usr/bin/env bash

MEMORY_FILE="$AGENT_DIR/memory.txt"
MAX_SIZE="1024k" 

# 1. Initialize memory.txt
> "$MEMORY_FILE"
echo "--> Directory Structure:" >> "$MEMORY_FILE"

# 2. Write Directory Tree
command find . -not -path '*/\.*' \
    -not -path '*/node_modules/*' \
    -not -path '*/venv/*' \
    -not -path '*/env/*' \
    -not -path '*/build/*' \
    -not -path '*/dist/*' \
    -not -path '*/__pycache__/*' \
    -not -path "$AGENT_DIR/*" | sort >> "$MEMORY_FILE"

echo -e "\n--> File Summaries (Memory Map):" >> "$MEMORY_FILE"
echo "🧠 Starting project memorization. This may take a minute..."

# 3. The Loop
command find . -type f -not -path '*/\.*' \
    -not -path '*/node_modules/*' \
    -not -path '*/venv/*' \
    -not -path '*/env/*' \
    -not -path '*/build/*' \
    -not -path '*/dist/*' \
    -not -path '*/__pycache__/*' \
    -not -path "$AGENT_DIR/*" \
    -size -"$MAX_SIZE" | while read -r file; do
    
    # Only process text files
    if ! file "$file" | grep -qiE 'text|json|csv|xml|empty'; then 
        continue
    fi

    echo "Memorizing $file..."
    
    # Clear the temporary context and read just this one file
    agent clear_memory > /dev/null
    agent read "$file" > /dev/null
    
    # Ask Gemini to compress the file into metadata
    SUMMARY=$(agent ask "Analyze this code concisely. Output ONLY a bulleted list containing: 1. Main purpose 2. Classes/Methods 3. Internal file dependencies 4. External dependencies.")

    # Append the summary to the permanent memory file
    echo -e "\n========================================" >> "$MEMORY_FILE"
    echo "File: $file" >> "$MEMORY_FILE"
    echo "========================================" >> "$MEMORY_FILE"
    echo "$SUMMARY" >> "$MEMORY_FILE"

done

echo -e "\n✅ Done! Compressed project memory saved to: $MEMORY_FILE"