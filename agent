#!/usr/bin/env bash

export AGENT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]:-$0}")")"
COMMAND="$1"
shift

if [[ -z "$COMMAND" ]]; then
    echo "Usage: agent <command> [args...]"
    echo -e "\nTools:"
    ls -1 "$AGENT_DIR/tools" 2>/dev/null | sed 's/^/  - /'
    echo -e "\nCreate/Involved Processes:"
    ls -1 "$AGENT_DIR/create" 2>/dev/null | sed 's/^/  - /'
    echo -e "\nSequences:"
    ls -1 "$AGENT_DIR/sequence" 2>/dev/null | sed 's/^/  - /'
    exit 1
fi

if [[ -x "$AGENT_DIR/tools/$COMMAND" ]]; then
    "$AGENT_DIR/tools/$COMMAND" "$@"
elif [[ -x "$AGENT_DIR/create/$COMMAND" ]]; then
    "$AGENT_DIR/create/$COMMAND" "$@"
elif [[ -x "$AGENT_DIR/sequence/$COMMAND" ]]; then
    "$AGENT_DIR/sequence/$COMMAND" "$@"
else
    echo "Error: '$COMMAND' not found in tools/, create/, or sequence/."
    exit 1
fi