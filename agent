#!/usr/bin/env bash
export AGENT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]:-$0}")")"
mkdir -p "$AGENT_DIR/sessions/.bindings"

# 1. Resolve Session (With Ghost-Tab Protection & Log Cleanup)
if [[ -z "$AGENT_SESSION_RESOLVED" ]]; then
    CURRENT_TTY=$(tty | sed 's|/|_|g')
    BINDING_FILE="$AGENT_DIR/sessions/.bindings/$CURRENT_TTY"
    if [[ -f "$BINDING_FILE" ]]; then
        BIND_DATA=$(cat "$BINDING_FILE")
        B_NAME="${BIND_DATA%:*}"
        B_PID="${BIND_DATA#*:}"
        
        # Check if the terminal process that started this session is still alive
        if [[ -z "$B_PID" || "$B_PID" == "$B_NAME" ]] || ps -p "$B_PID" >/dev/null 2>&1; then
            export SESSION_NAME="$B_NAME"
            export SESSION_DIR="$AGENT_DIR/sessions/$SESSION_NAME"
        else
            # The tab was closed! Wipe the abandoned logs and clean up the ghost binding.
            rm -f "$AGENT_DIR/sessions/$B_NAME/logs/terminal_raw.log"
            rm -f "$BINDING_FILE"
        fi
    fi
    export AGENT_SESSION_RESOLVED="1"
fi

# 2. Handle Model Tiers
export AGENT_MODEL="gemini-3-flash-preview"
NEW_ARGS=()
for arg in "$@"; do
    if [[ "$arg" == "-s" || "$arg" == "-smartest" ]]; then
        export AGENT_MODEL="gemini-3.1-pro-preview"
    else
        NEW_ARGS+=("$arg")
    fi
done
set -- "${NEW_ARGS[@]}"

COMMAND="$1"
shift
[[ -z "$COMMAND" ]] && COMMAND="help"

# 3. Session Enforcement
PUBLIC_CMDS="help start resume list delete stop ask"
if [[ -z "$SESSION_NAME" ]]; then
    if [[ ! " $PUBLIC_CMDS " =~ " $COMMAND " ]]; then
        echo "❌ Error: No active session found. Run 'agent start <name>' first."
        exit 1
    fi
fi

# 4. Routing (using 'exec' allows child scripts to target the parent shell directly)
if [[ -x "$AGENT_DIR/tools/$COMMAND" ]]; then exec "$AGENT_DIR/tools/$COMMAND" "$@"
elif [[ -x "$AGENT_DIR/manage/$COMMAND" ]]; then exec "$AGENT_DIR/manage/$COMMAND" "$@"
else
    echo "❌ Error: Command '$COMMAND' not found."
    exit 1
fi